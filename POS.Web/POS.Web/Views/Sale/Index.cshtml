
@model IEnumerable<POS.Web.Models.Sale>
@using POS.Web.Models

@{
    ViewData["Title"] = "Sales";
    var products = ViewBag.Products as List<Product>;
}

<div class="container mt-4">

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="bi bi-cart-plus me-2"></i> Create Sale
            </h5>
        </div>

        <div class="card-body p-4">

           
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <a href="/Product" class="btn btn-outline-secondary btn-sm mb-4">
                <i class="bi bi-arrow-left me-1"></i> Back To Products
            </a>

            <form asp-action="Create" asp-controller="Sale" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-semibold">Sale ID</label>
                    <input class="form-control" value="Auto Generated (e.g. 2026-04-30-01)" readonly disabled />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Timestamp</label>
                    <input class="form-control" id="timestampDisplay" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Select Product</label>
                    <select name="ProductId" class="form-select" id="productDropdown" required>
                        <option value="">-- Select Product --</option>
                        @if (products != null)
                        {
                            foreach (var item in products)
                            {
                                <option value="@item.Id" data-stock="@item.Stock">
                                    @item.Name (Stock: @item.Stock pcs)
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Available Stock</label>
                    <input type="text" id="stockDisplay" class="form-control" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Quantity</label>
                    <input name="Quantity" type="number" class="form-control" id="quantityInput" min="1" required />
                    <small id="stockWarning" class="text-danger"></small>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Price</label>
                    <input name="Price" type="number" step="0.01" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Barcode</label>
                    <input name="Barcode" class="form-control" />
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-save me-2"></i> Save Sale
                    </button>
                </div>
            </form>

        </div>
    </div>

  
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="bi bi-clock-history me-2"></i> Sales History
            </h5>
        </div>

        <div class="card-body p-0">
            <table class="table table-bordered table-striped table-hover mb-0">
                <thead class="table-white">
                    <tr>
                        <th>Sale ID</th>
                        <th>Product ID</th>
                        <th>Product Name</th>
                        <th>Quantity</th>
                        <th>Price</th>
                        <th>Barcode</th>
                        <th>Timestamp</th>
                        <th>Status</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var sale in Model)
                        {
                            var productName = products != null
                            ? products.FirstOrDefault(p => p.Id == sale.ProductId)?.Name ?? "-"
                            : "-";

                            <tr>
                                <td><span class="badge bg-secondary">@sale.SaleId</span></td>
                                <td>@sale.ProductId</td>
                                <td>@productName</td>
                                <td>@sale.Quantity</td>
                                <td>@sale.Price</td>
                                <td>@sale.Barcode</td>
                                <td>@sale.Timestamp.ToString("dd-MM-yyyy hh:mm tt")</td>
                                <td>
                                    @if (sale.Status == "Synced")
                                    {
                                        <span class="badge bg-success">Synced</span>
                                    }
                                    else if (sale.Status == "Failed")
                                    {
                                        <span class="badge bg-danger">Failed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                </td>
                                <td><strong>@(sale.Quantity * sale.Price)</strong></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center py-3 text-muted">No Sales Found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

<script>
    function updateTimestamp() {
        const now = new Date();
        const formatted = now.toLocaleString('en-GB', {
            day: '2-digit', month: '2-digit', year: 'numeric',
            hour: '2-digit', minute: '2-digit', second: '2-digit',
            hour12: true
        });
        document.getElementById("timestampDisplay").value = formatted;
    }
    updateTimestamp();
    setInterval(updateTimestamp, 1000);

    const productDropdown = document.getElementById("productDropdown");
    const stockDisplay = document.getElementById("stockDisplay");
    const quantityInput = document.getElementById("quantityInput");
    const stockWarning = document.getElementById("stockWarning");

    let currentStock = 0;

    productDropdown.addEventListener("change", function () {
        const selectedOption = this.options[this.selectedIndex];
        currentStock = parseInt(selectedOption.getAttribute("data-stock")) || 0;
        stockDisplay.value = currentStock + " pcs";
        stockWarning.innerText = "";
    });

    quantityInput.addEventListener("input", function () {
        const qty = parseInt(this.value) || 0;
        if (qty > currentStock) {
            stockWarning.innerText = "Not enough stock available!";
        } else {
            stockWarning.innerText = "";
        }
    });
</script>