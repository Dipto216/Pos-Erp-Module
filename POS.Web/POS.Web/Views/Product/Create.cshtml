@{
}
@model POS.Web.Models.Product


@{
    ViewData["Title"] = "Create Product";
}

<div class="container mt-4" style="max-width: 600px;">

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="bi bi-plus-circle me-2"></i> Create New Product
            </h5>
        </div>

        <div class="card-body p-4">

         
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

           

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-semibold">Product ID</label>
                    <input asp-for="Id" class="form-control" placeholder="Enter Product ID" />
                    <span asp-validation-for="Id" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Product Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter Product Name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Stock (pcs)</label>
                    <input asp-for="Stock" class="form-control" placeholder="Enter Stock Quantity" />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-save me-2"></i> Save Product
                    </button>
                </div>

               
            </form>
            
        </div>

        <a href="/Product" class="btn btn-outline-secondary btn-sm mb-4">
            <i class="bi bi-arrow-left me-1"></i> Back to Products
        </a>
    </div>

</div>