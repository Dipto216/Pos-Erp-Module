@{
}
@model IEnumerable<POS.Web.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="bi bi-box-seam me-2"></i> Product List
            </h5>
         
        </div>

        <div class="card-body p-3">

            <div class="mb-3 d-flex gap-2">
                <a href="/Sale" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-cart me-1"></i> Go To Sales
                </a>
                <a href="/Sync" class="btn btn-outline-success btn-sm">
                    <i class="bi bi-arrow-repeat me-1"></i> Go To Sync
                </a>
                <a href="/Product/Create" class="btn btn-light btn-sm">
                    <i class="bi bi-plus-circle me-1"></i> Product Create
                </a>
            </div>

            <table class="table table-bordered table-striped table-hover mb-0">
                <thead class="table-white">
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Stock</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var product in Model)
                        {
                            <tr>
                                <td>@product.Id</td>
                                <td>@product.Name</td>
                                <td>
                                    @if (product.Stock <= 5)
                                    {
                                        <span class="badge bg-danger">@product.Stock pcs</span>
                                    }
                                    else if (product.Stock <= 20)
                                    {
                                        <span class="badge bg-warning text-dark">@product.Stock pcs</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@product.Stock pcs</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-3 text-muted">No Products Found</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>